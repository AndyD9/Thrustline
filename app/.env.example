# Copy this file to .env and fill in the values.
# .env is git-ignored.

# Supabase project credentials (front-end, anon key is safe in the bundle since RLS is on)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Override sim-bridge URL (defaults to http://127.0.0.1:5055 when unset)
# VITE_SIM_BRIDGE_URL=http://127.0.0.1:5055
