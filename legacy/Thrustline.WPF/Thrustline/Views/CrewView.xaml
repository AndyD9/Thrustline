<UserControl x:Class="Thrustline.Views.CrewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignHeight="800" d:DesignWidth="1100">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Crew Management" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Left"/>
            <TextBlock Text="{Binding CrewCount, StringFormat={}{0} crew members}" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Right"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </DockPanel>

        <!-- Crew DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
            <DataGrid ItemsSource="{Binding Crew}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent"
                      RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="140"/>
                    <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="100"/>
                    <DataGridTextColumn Header="Experience" Binding="{Binding Experience, StringFormat={}{0:F0}h}" Width="90"/>
                    <DataGridTextColumn Header="Salary" Binding="{Binding Salary, Converter={StaticResource Currency}}" Width="90"/>

                    <!-- Duty Hours ProgressBar -->
                    <DataGridTemplateColumn Header="Duty Hours" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <ProgressBar Value="{Binding DutyHours}" Maximum="{Binding MaxDutyHours}" Height="16"
                                                 Background="{StaticResource SurfaceBrush}">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFatigued}" Value="True">
                                                        <Setter Property="Foreground" Value="#FFB86C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>
                                    <TextBlock Text="{Binding DutyHoursDisplay}" FontSize="10"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Aircraft" Binding="{Binding AssignedAircraft}" Width="120"/>

                    <!-- Status with color -->
                    <DataGridTemplateColumn Header="Status" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#33808080"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Active">
                                                    <Setter Property="Background" Value="#3350FA7B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Resting">
                                                    <Setter Property="Background" Value="#33FFB86C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Action Buttons -->
                    <DataGridTemplateColumn Header="Actions" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Assign" Command="{Binding DataContext.AssignCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="{StaticResource AccentBrush}" Foreground="White"
                                            BorderThickness="0" Padding="10,4" Margin="0,0,4,0" FontSize="11" Cursor="Hand"/>
                                    <Button Content="Unassign" Command="{Binding DataContext.UnassignCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            Padding="10,4" Margin="0,0,4,0" FontSize="11" Cursor="Hand"/>
                                    <Button Content="Fire" Command="{Binding DataContext.FireCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="#44FF5555" Foreground="#FF5555"
                                            BorderBrush="#FF5555" BorderThickness="1"
                                            Padding="10,4" FontSize="11" Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Hiring Pool Header -->
        <DockPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Hiring Pool" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Refresh" Command="{Binding RefreshHiringPoolCommand}"
                        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="14,6" Margin="0,0,8,0" FontSize="13" Cursor="Hand"/>
            </StackPanel>
        </DockPanel>

        <!-- Hiring Pool DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" MinHeight="180">
            <DataGrid ItemsSource="{Binding HiringPool}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent"
                      RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160"/>
                    <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="100"/>
                    <DataGridTextColumn Header="Experience" Binding="{Binding Experience, StringFormat={}{0:F0}h}" Width="100"/>
                    <DataGridTextColumn Header="Salary" Binding="{Binding Salary, Converter={StaticResource Currency}}" Width="100"/>
                    <DataGridTextColumn Header="Rating" Binding="{Binding Rating, StringFormat={}{0:F1}}" Width="70"/>
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Hire" Command="{Binding DataContext.HireCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="{StaticResource AccentBrush}" Foreground="White"
                                        BorderThickness="0" Padding="14,4" FontSize="11" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
