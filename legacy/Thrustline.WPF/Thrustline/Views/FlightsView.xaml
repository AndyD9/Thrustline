<UserControl x:Class="Thrustline.Views.FlightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Row -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Flight History" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Left"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding Flights.Count, StringFormat={}{0} flights}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="Export CSV" Command="{Binding ExportCsvCommand}"
                        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16,8" FontSize="13" Cursor="Hand"/>
            </StackPanel>
        </DockPanel>

        <!-- Flights DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Flights}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent"
                      RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=g}" Width="140"/>
                    <DataGridTextColumn Header="Departure" Binding="{Binding Departure}" Width="90"/>
                    <DataGridTextColumn Header="Arrival" Binding="{Binding Arrival}" Width="90"/>
                    <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="80"/>
                    <DataGridTextColumn Header="Distance" Binding="{Binding Distance, StringFormat={}{0} nm}" Width="90"/>

                    <!-- VS Column with color coding -->
                    <DataGridTemplateColumn Header="VS (fpm)" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding VerticalSpeed, StringFormat={}{0:F0}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHardLanding}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF5555"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsHardLanding}" Value="False">
                                                    <Setter Property="Foreground" Value="#50FA7B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, Converter={StaticResource Currency}}" Width="100"/>
                    <DataGridTextColumn Header="Fuel Cost" Binding="{Binding FuelCost, Converter={StaticResource Currency}}" Width="100"/>

                    <!-- Net Column with color coding -->
                    <DataGridTemplateColumn Header="Net" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Net, Converter={StaticResource Currency}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNetPositive}" Value="True">
                                                    <Setter Property="Foreground" Value="#50FA7B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsNetPositive}" Value="False">
                                                    <Setter Property="Foreground" Value="#FF5555"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
