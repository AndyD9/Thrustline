<UserControl x:Class="Thrustline.Views.AuthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignHeight="700" d:DesignWidth="500">

    <Grid>
        <!-- Centered Auth Card -->
        <Border Style="{StaticResource Card}" VerticalAlignment="Center" HorizontalAlignment="Center"
                Width="380" Padding="0">
            <StackPanel Margin="32">

                <!-- Logo / Title -->
                <TextBlock Text="T H R U S T L I N E" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Virtual Airline Manager" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <!-- Sign In / Sign Up Header -->
                <TextBlock FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Sign In"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSignUp}" Value="True">
                                    <Setter Property="Text" Value="Create Account"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Email -->
                <TextBlock Text="Email" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}" Padding="10,10" FontSize="14" Margin="0,0,0,14"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordInput"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="10,10" FontSize="14" Margin="0,0,0,6"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5555" FontSize="12"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                           Margin="0,0,0,8" TextWrapping="Wrap"/>

                <!-- Sign In / Sign Up Button -->
                <Button Command="{Binding AuthCommand}" Margin="0,10,0,0"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        BorderThickness="0" Padding="0,12" FontSize="15" FontWeight="SemiBold"
                        Cursor="Hand" HorizontalContentAlignment="Center">
                    <Button.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Sign In"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSignUp}" Value="True">
                                            <Setter Property="Text" Value="Create Account"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

                <!-- Toggle Link -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Don't have an account? "/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSignUp}" Value="True">
                                        <Setter Property="Text" Value="Already have an account? "/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Command="{Binding ToggleAuthModeCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource AccentBrush}" FontSize="12" Cursor="Hand" Padding="0">
                        <Button.Content>
                            <TextBlock TextDecorations="Underline">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Sign Up"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSignUp}" Value="True">
                                                <Setter Property="Text" Value="Sign In"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <!-- Divider -->
                <Grid Margin="0,22,0,18">
                    <Separator Background="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="or continue with" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Background="{StaticResource BackgroundBrush}" Padding="10,0"/>
                </Grid>

                <!-- OAuth Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Discord" Command="{Binding DiscordAuthCommand}"
                            Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Padding="0,10" FontSize="13" Cursor="Hand" HorizontalContentAlignment="Center"/>

                    <Button Grid.Column="2" Content="Google" Command="{Binding GoogleAuthCommand}"
                            Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Padding="0,10" FontSize="13" Cursor="Hand" HorizontalContentAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
