<UserControl x:Class="Thrustline.Views.OnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignHeight="700" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content Area -->
        <Border Grid.Row="0" Style="{StaticResource Card}" VerticalAlignment="Center" HorizontalAlignment="Center"
                Width="560" Padding="0">
            <StackPanel Margin="32">

                <!-- Step Indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <!-- Step 1 -->
                    <Ellipse Width="32" Height="32">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource SurfaceBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep1Active}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsStep1Complete}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Rectangle Width="40" Height="2" Fill="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                    <!-- Step 2 -->
                    <Ellipse Width="32" Height="32">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource SurfaceBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep2Active}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsStep2Complete}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Rectangle Width="40" Height="2" Fill="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                    <!-- Step 3 -->
                    <Ellipse Width="32" Height="32">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource SurfaceBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsStep3Complete}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Rectangle Width="40" Height="2" Fill="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                    <!-- Step 4 -->
                    <Ellipse Width="32" Height="32">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource SurfaceBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep4Active}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>

                <TextBlock Text="{Binding StepTitle}" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding StepDescription}" FontSize="13" TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextAlignment="Center" Margin="0,0,0,24"/>

                <!-- STEP 1: Company Info -->
                <StackPanel Visibility="{Binding IsStep1Active, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Company Name" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="10,8" FontSize="14" Margin="0,0,0,14"/>

                    <TextBlock Text="Hub ICAO" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding HubIcao, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="10,8" FontSize="14" Margin="0,0,0,14"
                             CharacterCasing="Upper" MaxLength="4"/>

                    <TextBlock Text="Airline Code (3 letters)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding AirlineCode, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="10,8" FontSize="14"
                             CharacterCasing="Upper" MaxLength="3"/>
                </StackPanel>

                <!-- STEP 2: Loan Selection -->
                <StackPanel Visibility="{Binding IsStep2Active, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding LoanOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="14" CornerRadius="6" Cursor="Hand"
                                        BorderThickness="2"
                                        Background="{StaticResource SurfaceBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectLoanCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Amount, StringFormat={}{0:C0}}" FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding InterestRate, StringFormat={}{0:P1} APR}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- STEP 3: Aircraft Selection -->
                <StackPanel Visibility="{Binding IsStep3Active, Converter={StaticResource BoolToVis}}">
                    <DataGrid ItemsSource="{Binding StarterAircraft}"
                              SelectedItem="{Binding SelectedStarterAircraft}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" Background="Transparent"
                              RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                              SelectionMode="Single" MaxHeight="260">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Aircraft" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding AircraftType}" Width="100"/>
                            <DataGridTextColumn Header="Range" Binding="{Binding Range, StringFormat={}{0} nm}" Width="80"/>
                            <DataGridTextColumn Header="Pax" Binding="{Binding Passengers}" Width="50"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding PurchasePrice, Converter={StaticResource Currency}}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- STEP 4: Confirm -->
                <StackPanel Visibility="{Binding IsStep4Active, Converter={StaticResource BoolToVis}}">
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="16" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Company:" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CompanyName}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Hub:" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HubIcao}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Airline Code:" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AirlineCode}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Loan:" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedLoanSummary}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Aircraft:" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedStarterAircraft.Name}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Navigation Buttons -->
        <DockPanel Grid.Row="1" Margin="32,0,32,32" HorizontalAlignment="Center" Width="560">
            <Button Content="Back" Command="{Binding PreviousStepCommand}"
                    DockPanel.Dock="Left"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Padding="24,10" FontSize="14" Cursor="Hand"/>

            <Button Command="{Binding NextStepCommand}"
                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Padding="24,10" FontSize="14" FontWeight="SemiBold" Cursor="Hand">
                <Button.Content>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Next"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep4Active}" Value="True">
                                        <Setter Property="Text" Value="Launch Airline"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button.Content>
            </Button>
        </DockPanel>
    </Grid>
</UserControl>
