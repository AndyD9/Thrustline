<UserControl x:Class="Thrustline.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignHeight="650" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="560">

            <!-- Page Header -->
            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

            <!-- Company Settings Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                <StackPanel Margin="20">
                    <TextBlock Text="Company Settings" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <!-- Company Name -->
                    <TextBlock Text="Company Name" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="10,8" FontSize="14" Margin="0,0,0,14"/>

                    <!-- Hub ICAO -->
                    <TextBlock Text="Hub ICAO" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding HubIcao, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="10,8" FontSize="14" Margin="0,0,0,14"
                             CharacterCasing="Upper" MaxLength="4"/>

                    <!-- Airline Code -->
                    <TextBlock Text="Airline Code" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding AirlineCode, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="10,8" FontSize="14" Margin="0,0,0,14"
                             CharacterCasing="Upper" MaxLength="3"/>

                    <!-- SimBrief Username -->
                    <TextBlock Text="SimBrief Username" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SimBriefUsername, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="10,8" FontSize="14" Margin="0,0,0,20"/>

                    <!-- Save Button -->
                    <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}"
                            Background="{StaticResource AccentBrush}" Foreground="White"
                            BorderThickness="0" Padding="24,10" FontSize="14" FontWeight="SemiBold"
                            HorizontalAlignment="Left" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Danger Zone -->
            <Border BorderBrush="#FF5555" BorderThickness="1" CornerRadius="8"
                    Background="#11FF5555" Margin="0,0,0,20">
                <StackPanel Margin="20">
                    <TextBlock Text="Danger Zone" FontSize="18" FontWeight="SemiBold"
                               Foreground="#FF5555" Margin="0,0,0,12"/>
                    <TextBlock Text="These actions are irreversible. Proceed with caution." FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                    <DockPanel Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Reset Company Data" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Delete all flights, finances, fleet, and crew data." FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Content="Reset Data" Command="{Binding ResetCompanyCommand}"
                                DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#FF5555" Foreground="White"
                                BorderThickness="0" Padding="16,8" FontSize="13" Cursor="Hand"/>
                    </DockPanel>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,4,0,12"/>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Sign Out" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Sign out of your Thrustline account." FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Content="Sign Out" Command="{Binding SignOutCommand}"
                                DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource SurfaceBrush}" Foreground="#FF5555"
                                BorderBrush="#FF5555" BorderThickness="1"
                                Padding="16,8" FontSize="13" Cursor="Hand"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
