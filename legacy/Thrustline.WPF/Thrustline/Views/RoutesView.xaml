<UserControl x:Class="Thrustline.Views.RoutesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignHeight="750" d:DesignWidth="1100">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Discovered Routes Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Discovered Routes" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DiscoveredRoutes.Count, StringFormat={}{0} routes}" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Right"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </DockPanel>

        <!-- Discovered Routes DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,24">
            <DataGrid ItemsSource="{Binding DiscoveredRoutes}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent"
                      RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Departure" Binding="{Binding Departure}" Width="100"/>
                    <DataGridTextColumn Header="Arrival" Binding="{Binding Arrival}" Width="100"/>
                    <DataGridTextColumn Header="Distance" Binding="{Binding Distance, StringFormat={}{0} nm}" Width="90"/>
                    <DataGridTextColumn Header="Flights" Binding="{Binding FlightCount}" Width="70"/>
                    <DataGridTextColumn Header="Total Net" Binding="{Binding TotalNet, Converter={StaticResource Currency}}" Width="110"/>
                    <DataGridTemplateColumn Header="Avg VS" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AvgVerticalSpeed, StringFormat={}{0:F0} fpm}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGoodAvgVS}" Value="True">
                                                    <Setter Property="Foreground" Value="#50FA7B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsGoodAvgVS}" Value="False">
                                                    <Setter Property="Foreground" Value="#FF5555"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Save" Command="{Binding DataContext.SaveRouteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="{StaticResource AccentBrush}" Foreground="White"
                                        BorderThickness="0" Padding="12,4" FontSize="11" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Saved Routes Header -->
        <DockPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Saved Routes" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SavedRoutes.Count, StringFormat={}{0} saved}" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Right"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Saved Routes DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding SavedRoutes}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent"
                      RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Departure" Binding="{Binding Departure}" Width="100"/>
                    <DataGridTextColumn Header="Arrival" Binding="{Binding Arrival}" Width="100"/>
                    <DataGridTextColumn Header="Distance" Binding="{Binding Distance, StringFormat={}{0} nm}" Width="90"/>
                    <DataGridTextColumn Header="Flights" Binding="{Binding FlightCount}" Width="70"/>
                    <DataGridTextColumn Header="Total Net" Binding="{Binding TotalNet, Converter={StaticResource Currency}}" Width="110"/>
                    <DataGridTextColumn Header="Avg VS" Binding="{Binding AvgVerticalSpeed, StringFormat={}{0:F0} fpm}" Width="90"/>
                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Delete" Command="{Binding DataContext.DeleteSavedRouteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="#44FF5555" Foreground="#FF5555"
                                        BorderBrush="#FF5555" BorderThickness="1"
                                        Padding="10,4" FontSize="11" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
