<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════════════
         GLASSMORPHISM THEME — Thrustline
         Frosted glass, luminous borders, depth through transparency
         ══════════════════════════════════════════════════════════════════ -->

    <!-- ── Base Colors ──────────────────────────────────────────────── -->
    <Color x:Key="BgDark">#FF0A0E17</Color>
    <Color x:Key="BgMid">#FF111827</Color>
    <Color x:Key="GlassLight">#18FFFFFF</Color>
    <Color x:Key="GlassMedium">#0DFFFFFF</Color>
    <Color x:Key="GlassBorder">#22FFFFFF</Color>
    <Color x:Key="GlassBorderHover">#44FFFFFF</Color>
    <Color x:Key="TextWhite">#FFF1F5F9</Color>
    <Color x:Key="TextMuted">#FF94A3B8</Color>
    <Color x:Key="TextDim">#FF64748B</Color>
    <Color x:Key="Emerald">#FF34D399</Color>
    <Color x:Key="EmeraldGlow">#2234D399</Color>
    <Color x:Key="EmeraldBright">#FF10B981</Color>
    <Color x:Key="RedSoft">#FFEF4444</Color>
    <Color x:Key="AmberSoft">#FFFBBF24</Color>
    <Color x:Key="BlueSoft">#FF60A5FA</Color>

    <!-- ── Solid Brushes ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BgDark}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource BgMid}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource GlassMedium}" />
    <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource GlassLight}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource GlassBorder}" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource GlassBorderHover}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextWhite}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Emerald}" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource EmeraldGlow}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource RedSoft}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource AmberSoft}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource BlueSoft}" />

    <!-- ── Background gradient (subtle radial glow) ─────────────────── -->
    <LinearGradientBrush x:Key="PageBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0A0E17" Offset="0" />
        <GradientStop Color="#FF0F1729" Offset="0.5" />
        <GradientStop Color="#FF0A0E17" Offset="1" />
    </LinearGradientBrush>

    <!-- ── Sidebar gradient ─────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF111827" Offset="0" />
        <GradientStop Color="#FF0D1321" Offset="1" />
    </LinearGradientBrush>

    <!-- ── Global TextBlock style ───────────────────────────────────── -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ── Glass Card ───────────────────────────────────────────────── -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.15" Color="Black" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Glass Card (accent glow variant) ─────────────────────────── -->
    <Style x:Key="CardAccent" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="{StaticResource AccentGlowBrush}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.2" Color="{StaticResource Emerald}" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── KPI Card ─────────────────────────────────────────────────── -->
    <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="MinWidth" Value="180" />
    </Style>

    <!-- ── Primary Button (emerald glass) ───────────────────────────── -->
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" CornerRadius="8" Padding="{TemplateBinding Padding}"
                            Background="{StaticResource AccentBrush}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.25" Color="{StaticResource Emerald}" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource EmeraldBright}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Ghost Button (transparent glass) ─────────────────────────── -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" CornerRadius="8" Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource GlassBrush}" />
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BorderHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TextBox (glass input) ────────────────────────────────────── -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource GlassBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource AccentGlowBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.2" Color="{StaticResource Emerald}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── PasswordBox (glass input) ────────────────────────────────── -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource GlassBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- ── DataGrid (glass table) ───────────────────────────────────── -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource GlassBrush}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontSize" Value="12.5" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource GlassBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentGlowBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ProgressBar (glass) ──────────────────────────────────────── -->
    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="Background" Value="{StaticResource GlassBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border CornerRadius="3" Background="{TemplateBinding Background}" />
                        <Border x:Name="PART_Track" />
                        <Border x:Name="PART_Indicator" CornerRadius="3"
                                Background="{TemplateBinding Foreground}"
                                HorizontalAlignment="Left" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ScrollBar (minimal) ──────────────────────────────────────── -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ── Separator ────────────────────────────────────────────────── -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BorderBrush}" />
        <Setter Property="Height" Value="1" />
    </Style>

</ResourceDictionary>
