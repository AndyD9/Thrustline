<Window x:Class="Thrustline.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Thrustline.ViewModels"
        Title="Thrustline" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="208" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,20,20,24">
                    <TextBlock FontSize="22" FontWeight="Bold">
                        <Run Text="Thrust" Foreground="{StaticResource AccentBrush}" />
                        <Run Text="line" Foreground="{StaticResource TextPrimaryBrush}" />
                    </TextBlock>
                    <TextBlock Text="Virtual Airline" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,2,0,0" />
                </StackPanel>

                <!-- Status indicators at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16">
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SimStatus}" Value="connected">
                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SimStatus}" Value="mock">
                                            <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding SimStatus, StringFormat='Sim: {0}'}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding SyncStatus, StringFormat='Sync: {0}'}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Margin="8,0">
                    <Button Content="Overview"  Command="{Binding NavigateCommand}" CommandParameter="Dashboard" Margin="0,2" Style="{StaticResource NavButton}" />
                    <Button Content="Flights"   Command="{Binding NavigateCommand}" CommandParameter="Flights"   Margin="0,2" Style="{StaticResource NavButton}" />
                    <Button Content="Finances"  Command="{Binding NavigateCommand}" CommandParameter="Finances"  Margin="0,2" Style="{StaticResource NavButton}" />
                    <Button Content="Fleet"     Command="{Binding NavigateCommand}" CommandParameter="Fleet"     Margin="0,2" Style="{StaticResource NavButton}" />
                    <Button Content="Crew"      Command="{Binding NavigateCommand}" CommandParameter="Crew"      Margin="0,2" Style="{StaticResource NavButton}" />
                    <Button Content="Routes"    Command="{Binding NavigateCommand}" CommandParameter="Routes"    Margin="0,2" Style="{StaticResource NavButton}" />
                    <Button Content="Dispatch"  Command="{Binding NavigateCommand}" CommandParameter="Dispatch"  Margin="0,2" Style="{StaticResource NavButton}" />
                    <Button Content="Settings"  Command="{Binding NavigateCommand}" CommandParameter="Settings"  Margin="0,2" Style="{StaticResource NavButton}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Content area ───────────────────────────────────────────── -->
        <DockPanel Grid.Column="1">
            <!-- Live flight bar -->
            <Border DockPanel.Dock="Top" Background="#1134D399" Padding="16,10"
                    Visibility="{Binding IsFlying, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DepartureIcao}" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text=" — " Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding CurrentAircraftType}" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding Altitude, StringFormat=' | {0:N0} ft'}" Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0,0,0" />
                    <TextBlock Text="{Binding GroundSpeed, StringFormat=' | {0:N0} kts'}" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Page content -->
            <ContentControl Content="{Binding CurrentPage}" Margin="24,20" />
        </DockPanel>
    </Grid>
</Window>
