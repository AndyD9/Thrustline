<Application x:Class="Thrustline.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Thrustline.Converters"
             xmlns:vm="clr-namespace:Thrustline.ViewModels"
             xmlns:views="clr-namespace:Thrustline.Views">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
            <converters:CurrencyConverter x:Key="Currency" />

            <!-- Nav button style (text left-aligned, no background) -->
            <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1134D399" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- DataTemplates: ViewModel → View mapping -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:FlightsViewModel}"><views:FlightsView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:FinancesViewModel}"><views:FinancesView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:FleetViewModel}"><views:FleetView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:CrewViewModel}"><views:CrewView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:RoutesViewModel}"><views:RoutesView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:DispatchViewModel}"><views:DispatchView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:AuthViewModel}"><views:AuthView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:OnboardingViewModel}"><views:OnboardingView /></DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
