<UserControl x:Class="Thrustline.Views.FleetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignHeight="800" d:DesignWidth="1100">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <TextBlock Grid.Row="0" Text="Fleet Management" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

        <!-- Fleet DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
            <DataGrid ItemsSource="{Binding Fleet}"
                      SelectedItem="{Binding SelectedAircraft}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent"
                      RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding AircraftType}" Width="130"/>

                    <!-- Health ProgressBar -->
                    <DataGridTemplateColumn Header="Health" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <ProgressBar Value="{Binding HealthPercent}" Maximum="100" Height="16"
                                                 Background="{StaticResource SurfaceBrush}">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar">
                                                <Setter Property="Foreground" Value="#50FA7B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLowHealth}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>
                                    <TextBlock Text="{Binding HealthPercent, StringFormat={}{0}%}" FontSize="10"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Hours" Binding="{Binding TotalHours, StringFormat={}{0:F0}h}" Width="70"/>
                    <DataGridTextColumn Header="Cycles" Binding="{Binding Cycles}" Width="60"/>
                    <DataGridTextColumn Header="Ownership" Binding="{Binding Ownership}" Width="90"/>
                    <DataGridTextColumn Header="Monthly Cost" Binding="{Binding MonthlyCost, Converter={StaticResource Currency}}" Width="100"/>

                    <!-- Action Buttons -->
                    <DataGridTemplateColumn Header="Actions" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Activate" Command="{Binding DataContext.ActivateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="{StaticResource AccentBrush}" Foreground="White"
                                            BorderThickness="0" Padding="10,4" Margin="0,0,4,0" FontSize="11" Cursor="Hand"/>
                                    <Button Content="Maintain" Command="{Binding DataContext.MaintainCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            Padding="10,4" Margin="0,0,4,0" FontSize="11" Cursor="Hand"/>
                                    <Button Content="Sell" Command="{Binding DataContext.SellCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="#44FF5555" Foreground="#FF5555"
                                            BorderBrush="#FF5555" BorderThickness="1"
                                            Padding="10,4" FontSize="11" Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Catalog Header -->
        <TextBlock Grid.Row="2" Text="Aircraft Catalog" FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

        <!-- Catalog Grid -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" MinHeight="200">
            <DataGrid ItemsSource="{Binding Catalog}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent"
                      RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Aircraft" Binding="{Binding Name}" Width="180"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding AircraftType}" Width="120"/>
                    <DataGridTextColumn Header="Range (nm)" Binding="{Binding Range}" Width="90"/>
                    <DataGridTextColumn Header="Pax" Binding="{Binding Passengers}" Width="60"/>
                    <DataGridTextColumn Header="Purchase" Binding="{Binding PurchasePrice, Converter={StaticResource Currency}}" Width="110"/>
                    <DataGridTextColumn Header="Lease/mo" Binding="{Binding LeasePrice, Converter={StaticResource Currency}}" Width="100"/>
                    <DataGridTemplateColumn Header="" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Buy" Command="{Binding DataContext.BuyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="{StaticResource AccentBrush}" Foreground="White"
                                            BorderThickness="0" Padding="12,4" Margin="0,0,6,0" FontSize="11" Cursor="Hand"/>
                                    <Button Content="Lease" Command="{Binding DataContext.LeaseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            Padding="12,4" FontSize="11" Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
