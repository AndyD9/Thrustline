<UserControl x:Class="Thrustline.Views.FinancesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignHeight="750" d:DesignWidth="1100">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <TextBlock Grid.Row="0" Text="Finances" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

        <!-- Capital + Loan Row -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <!-- Capital Display -->
            <Border Style="{StaticResource Card}" Width="280" Margin="0,0,16,0">
                <StackPanel Margin="16">
                    <TextBlock Text="Available Capital" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Capital, StringFormat={}{0:C0}}" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0"/>
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,12"/>
                    <DockPanel>
                        <TextBlock Text="Total Revenue" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:C0}}" Foreground="#50FA7B"
                                   FontSize="12" HorizontalAlignment="Right"/>
                    </DockPanel>
                    <DockPanel Margin="0,6,0,0">
                        <TextBlock Text="Total Expenses" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding TotalExpenses, StringFormat={}{0:C0}}" Foreground="#FF5555"
                                   FontSize="12" HorizontalAlignment="Right"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Loan Card -->
            <Border Style="{StaticResource Card}" Width="340" Margin="0,0,16,0">
                <StackPanel Margin="16">
                    <TextBlock Text="Active Loan" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Principal" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding LoanPrincipal, StringFormat={}{0:C0}}" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Remaining" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding LoanRemaining, StringFormat={}{0:C0}}" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="0" Grid.Row="1">
                            <TextBlock Text="Monthly Payment" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding LoanMonthly, StringFormat={}{0:C0}}" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#FFB86C"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1">
                            <TextBlock Text="Interest Rate" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding LoanInterestRate, StringFormat={}{0:P1}}" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Repayment Progress" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,14,0,4"/>
                    <ProgressBar Value="{Binding LoanProgress}" Maximum="100" Height="6"
                                 Foreground="{StaticResource AccentBrush}" Background="{StaticResource SurfaceBrush}"/>
                    <TextBlock Text="{Binding LoanProgress, StringFormat={}{0:F0}% paid}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Transactions Header -->
        <DockPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Transactions" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <Button Content="Export" Command="{Binding ExportTransactionsCommand}"
                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                    Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Padding="16,6" FontSize="13" Cursor="Hand"/>
        </DockPanel>

        <!-- Transactions DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Transactions}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="Transparent"
                      RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=g}" Width="140"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="120"/>
                    <DataGridTemplateColumn Header="Amount" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Amount, Converter={StaticResource Currency}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCredit}" Value="True">
                                                    <Setter Property="Foreground" Value="#50FA7B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsCredit}" Value="False">
                                                    <Setter Property="Foreground" Value="#FF5555"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
