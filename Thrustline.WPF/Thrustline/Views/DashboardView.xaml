<UserControl x:Class="Thrustline.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}"
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <TextBlock Grid.Row="0" Text="Dashboard" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

        <!-- KPI Cards -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <!-- Capital Card -->
            <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16">
                <StackPanel Margin="16">
                    <TextBlock Text="Capital" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Capital, StringFormat={}{0:C0}}" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="Available Funds" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Flights Card -->
            <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16">
                <StackPanel Margin="16">
                    <TextBlock Text="Total Flights" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalFlights}" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="Completed Flights" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Fleet Size Card -->
            <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16">
                <StackPanel Margin="16">
                    <TextBlock Text="Fleet Size" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding FleetSize}" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="Active Aircraft" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Reputation Card -->
            <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16">
                <StackPanel Margin="16">
                    <TextBlock Text="Reputation" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="{Binding Reputation, StringFormat={}{0:F1}}" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text=" / 5.0" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding Reputation}" Maximum="5" Height="4" Margin="0,8,0,0"
                                 Foreground="{StaticResource AccentBrush}" Background="{StaticResource SurfaceBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Recent Flights -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Recent Flights" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="16,12"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding RecentFlights}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          BorderThickness="0" Background="Transparent"
                          RowBackground="Transparent" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                        <DataGridTextColumn Header="Departure" Binding="{Binding Departure}" Width="90"/>
                        <DataGridTextColumn Header="Arrival" Binding="{Binding Arrival}" Width="90"/>
                        <DataGridTextColumn Header="Aircraft" Binding="{Binding AircraftName}" Width="160"/>
                        <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="80"/>
                        <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, Converter={StaticResource Currency}}" Width="100"/>
                        <DataGridTextColumn Header="Net" Binding="{Binding Net, Converter={StaticResource Currency}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
