<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Thrustline.Bridge</RootNamespace>
    <AssemblyName>sim-bridge</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <!-- Supabase .NET client : écritures depuis sim-bridge (flights, transactions, capital update) -->
    <PackageReference Include="supabase-csharp" Version="0.16.2" />
  </ItemGroup>

  <!-- SimConnect SDK (Windows only). The managed wrapper DLL lives in the MSFS SDK.
       On Windows dev, set MSFS_SDK env var to the installed SDK path and uncomment below.
       For now we build cross-platform against the Mock client only. -->
  <!--
  <ItemGroup Condition="'$(OS)' == 'Windows_NT'">
    <Reference Include="Microsoft.FlightSimulator.SimConnect">
      <HintPath>$(MSFS_SDK)\SimConnect SDK\lib\managed\Microsoft.FlightSimulator.SimConnect.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
  -->

</Project>
